{
  "name": "graphroots",
  "version": "0.6.0",
  "description": "An interactive, versioned map of Blues roots and branches.",
  "private": true,
  "license": "MIT",
  "author": "Elkaïoum M. Moutuou",
  "homepage": "https://elkMm.github.io/GraphRoots/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elkMm/GraphRoots.git"
  },
  "bugs": {
    "url": "https://github.com/elkMm/GraphRoots/issues"
  },
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node --import tsx scripts/validate-corpus.ts && node --import tsx scripts/build-graph-index.ts && node --import tsx scripts/export-public-data.ts && astro build && node --import tsx scripts/validate-built-site.ts",
    "preview": "astro preview",
    "validate:corpus": "node --import tsx scripts/validate-corpus.ts",
    "build:index": "node --import tsx scripts/build-graph-index.ts",
    "export:data": "node --import tsx scripts/export-public-data.ts",
    "research:wikipedia-connections": "node scripts/research-wikipedia-connections.mjs",
    "generate": "node --import tsx scripts/validate-corpus.ts && node --import tsx scripts/build-graph-index.ts && node --import tsx scripts/export-public-data.ts",
    "check": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run check && pnpm run validate:corpus && pnpm run test"
  },
  "dependencies": {
    "@astrojs/svelte": "^9.0.1",
    "astro": "^7.1.3",
    "d3": "^7.9.0",
    "svelte": "^5.56.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "eslint-plugin-svelte": "^3.22.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^4.1.1",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
